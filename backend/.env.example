# Copy this file to .env (run ONLY this line — no extra words after it):
#   cp .env.example .env
#
# Then set DATABASE_URL to a database that actually exists on your machine.

# --- Option A: Docker Postgres (matches docker-compose.yml in this folder) ---
# Start DB:  docker compose up -d
# DATABASE_URL=postgresql+psycopg2://holistica:holistica@localhost:5432/holistica_health

# --- Option B: Local Postgres with your macOS username (common Homebrew install) ---
# Replace YOUR_USER with the output of: whoami
# Create DB once:  createdb holistica_health
# DATABASE_URL=postgresql+psycopg2://YOUR_USER@localhost:5432/holistica_health

# --- Option C: Default superuser "postgres" with password ---
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/holistica_health

# Active URL (pick one pattern above and uncomment, or paste your own):
DATABASE_URL=postgresql+psycopg2://holistica:holistica@localhost:5432/holistica_health

# Comma-separated browser origins allowed to call the API (Vite default: 5173)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Gemini (Step 3)
GEMINI_API_KEY=
# Optional override (default in app/config.py is gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# IMMEDIATE_HISTORY_LIMIT=3
# SEMANTIC_HISTORY_LIMIT=5
